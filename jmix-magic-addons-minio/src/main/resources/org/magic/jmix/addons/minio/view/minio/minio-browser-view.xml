<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://minioBrowserView.title"
      focusComponent="bucketDataGrid">
    <actions>
        <!-- Bucket actions -->
        <action id="createBucketAction" text="msg://minioBrowserView.createBucket" icon="PLUS"/>
        <action id="renameBucketAction" text="msg://minioBrowserView.renameBucket" icon="EDIT"/>
        <action id="deleteBucketAction" text="msg://minioBrowserView.deleteBucket" icon="TRASH"/>
        <action id="refreshBucketAction" text="msg://minioBrowserView.refresh" icon="REFRESH"/>
        <action id="lifecycleBucketAction" text="msg://minioBrowserView.lifecycleConfig" icon="CLOCK"/>
        <!-- File actions -->
        <action id="createFolderAction" text="msg://minioBrowserView.createFolder" icon="FOLDER_ADD"/>
        <action id="uploadFileAction" text="msg://minioBrowserView.uploadFile" icon="FILE_ADD"/>
        <action id="uploadFolderAction" text="msg://minioBrowserView.uploadFolder" icon="FOLDER_ADD"/>
        <action id="downloadAction" text="msg://minioBrowserView.download" icon="DOWNLOAD"/>
        <action id="selectAllFilesAction" text="msg://minioBrowserView.selectAll" icon="CHECK"/>
        <action id="deleteFilesAction" text="msg://minioBrowserView.delete" icon="TRASH"/>
        <action id="refreshFileAction" text="msg://minioBrowserView.refresh" icon="REFRESH"/>
        <action id="selectFolderContentsAction" text="msg://minioBrowserView.selectFolderContents" icon="CHECK"/>
    </actions>
    <layout>
        <split id="mainSplit" orientation="HORIZONTAL" width="100%" height="100%"
               splitterPosition="30">

            <!-- 左侧：Bucket 列表 -->
            <vbox id="bucketPanel" width="100%" height="100%" padding="false" classNames="pl-xxs pr-s" expand="bucketDataGrid">
                <hbox id="bucketToolbar" classNames="buttons-panel" width="100%">
                    <button id="createBucketBtn" action="createBucketAction" themeNames="primary"/>
                    <dropdownButton id="bucketMoreBtn" text="msg://minioBrowserView.more"
                                    icon="ELLIPSIS_DOTS_H">
                        <items>
                            <actionItem id="lifecycleBucketItem" ref="lifecycleBucketAction"/>
                            <actionItem id="renameBucketItem" ref="renameBucketAction"/>
                            <actionItem id="deleteBucketItem" ref="deleteBucketAction"/>
                        </items>
                    </dropdownButton>
                    <button id="refreshBucketBtn" action="refreshBucketAction"/>
                </hbox>

                <dataGrid id="bucketDataGrid" width="100%" height="100%"
                          selectionMode="SINGLE" metaClass="minio_MinioBucketDto">
                    <contextMenu>
                        <item action="createBucketAction" icon="PLUS"/>
                        <item action="renameBucketAction" icon="EDIT"/>
                        <item action="deleteBucketAction" icon="TRASH"/>
                        <separator/>
                        <item action="refreshBucketAction" icon="REFRESH"/>
                    </contextMenu>
                </dataGrid>
            </vbox>

            <!-- 右侧：文件列表 -->
            <vbox id="filePanel" width="100%" height="100%" padding="false" classNames="pl-s" expand="fileTreeGrid">
                <hbox id="fileToolbar" classNames="buttons-panel" width="100%" expand="searchField">
                    <button id="createFolderBtn" action="createFolderAction"/>
                    <dropdownButton id="uploadBtn" text="msg://minioBrowserView.upload"
                                    icon="UPLOAD">
                        <items>
                            <actionItem id="uploadFileItem" ref="uploadFileAction"/>
                            <actionItem id="uploadFolderItem" ref="uploadFolderAction"/>
                        </items>
                    </dropdownButton>
                    <button id="downloadFileBtn" action="downloadAction"/>
                    <dropdownButton id="fileMoreBtn" text="msg://minioBrowserView.more"
                                    icon="ELLIPSIS_DOTS_H">
                        <items>
                            <actionItem id="selectAllFilesItem" ref="selectAllFilesAction"/>
                            <actionItem id="deleteFilesItem" ref="deleteFilesAction"/>
                        </items>
                    </dropdownButton>
                    <textField id="searchField" placeholder="msg://minioBrowserView.searchPlaceholder"
                               clearButtonVisible="true">
                        <prefix>
                            <icon icon="SEARCH"/>
                        </prefix>
                    </textField>
                    <button id="refreshFileBtn" action="refreshFileAction"/>
                </hbox>

                <treeDataGrid id="fileTreeGrid" width="100%" height="100%"
                              selectionMode="MULTI" metaClass="minio_MinioTreeNode"
                              hierarchyProperty="parent">
                    <contextMenu id="fileTreeGridContextMenu">
                        <item action="createFolderAction" icon="FOLDER_ADD"/>
                        <item action="uploadFileAction" icon="FILE_ADD"/>
                        <item action="uploadFolderAction" icon="FOLDER_ADD"/>
                        <separator/>
                        <item action="downloadAction" icon="DOWNLOAD"/>
                        <separator/>
                        <item id="selectFolderContentsItem" action="selectFolderContentsAction" icon="TASKS"/>
                        <item action="selectAllFilesAction" icon="CHECK"/>
                        <item action="deleteFilesAction" icon="TRASH"/>
                        <separator/>
                        <item action="refreshFileAction" icon="REFRESH"/>
                    </contextMenu>
                </treeDataGrid>
            </vbox>

        </split>
    </layout>
</view>
